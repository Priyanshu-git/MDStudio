    "@codemirror/view": "6.41.0",
    "dexie": "4.4.2",
    "firebase": "12.12.0",
    "mermaid": "11.14.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "10.1.0",
    "react-router-dom": "7.14.0",
    "rehype-katex": "7.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "shiki": "4.0.2",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/jest-dom": "6.9.1",
