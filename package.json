    "jsdom": "24.1.3",
    "postcss": "8.5.9",
    "prettier": "3.8.2",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1",
    "vite": "5.4.21",
    "vite-plugin-pwa": "0.20.5",
    "vitest": "1.6.1",
    "workbox-build": "7.4.1"
