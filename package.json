    "jsdom": "^24.1.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^1.6.0",
    "workbox-build": "^7.4.1"
